    "@types/marked": "^5.0.2",
    "axios": "^1.13.5",
    "dompurify": "^3.3.3",
    "dotenv": "^17.3.1",
    "firebase": "^12.11.0",
    "lucide-react": "^0.294.0",
    "marked": "^17.0.4",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-markdown": "^10.1.0",
    "socket.io-client": "^4.8.3",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@types/node": "^25.0.3",
    "@types/react": "^18.2.43",
